        <mxCell id="surface_label" value="ジオメトリ表面（デプスバッファ）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#4b5563;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="120" y="395" width="200" height="16" as="geometry"/>
        </mxCell>

