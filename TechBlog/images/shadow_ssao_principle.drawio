        <mxCell id="ssao_label" value="SSAO: 球体サンプリング" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#991b1b;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="565" y="108" width="180" height="20" as="geometry"/>
        </mxCell>
        <!-- Surface -->
        <mxCell id="ssao_surface" value="" style="endArrow=none;html=1;strokeColor=#6b7280;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="240" as="sourcePoint"/>
            <mxPoint x="740" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Full sphere -->
        <mxCell id="ssao_sphere" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#93c5fd;strokeWidth=2;dashed=1;" vertex="1" parent="1">
