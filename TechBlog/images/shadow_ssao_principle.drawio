          <mxGeometry x="300" y="180" width="30" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="wall_label" value="壁（遮蔽物）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#4b5563;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="280" y="160" width="80" height="16" as="geometry"/>
