        <!-- Left side: Sampling concept -->
        <mxCell id="left_title" value="1. サンプリング" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#1e40af;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="130" height="25" as="geometry"/>
        </mxCell>

