          <mxGeometry x="105" y="220" width="200" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="sphere_label" value="サンプリング球体" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#1e40af;fontFamily=Helvetica Neue;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="130" y="200" width="110" height="16" as="geometry"/>
