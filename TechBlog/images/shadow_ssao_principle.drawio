          <mxGeometry x="545" y="355" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="formula" value="AO(P) = (遮蔽サンプル数) / (全サンプル数)&#xa;遮蔽判定: depth(Sample) &gt; depthBuffer(Sample.screenPos)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#4b5563;fontFamily=Helvetica Neue;" vertex="1" parent="1">
