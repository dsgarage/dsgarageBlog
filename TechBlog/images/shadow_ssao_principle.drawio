        <mxCell id="ssao_p" value="P" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1e40af;strokeColor=#1e3a8a;fontColor=#ffffff;fontSize=10;fontStyle=1;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="640" y="210" width="20" height="20" as="geometry"/>
        </mxCell>
        <!-- Normal arrow -->
        <mxCell id="ssao_normal" value="N" style="endArrow=classic;html=1;strokeColor=#1e40af;strokeWidth=1.5;fontColor=#1e40af;fontSize=9;fontFamily=Helvetica Neue;" edge="1" parent="1">
