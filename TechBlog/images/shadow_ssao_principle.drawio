            <mxPoint x="650" y="215" as="sourcePoint"/>
            <mxPoint x="650" y="155" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Problem area -->
        <mxCell id="ssao_problem" value="裏側にもサンプルが&#xa;落ちる → 自己遮蔽" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#991b1b;fontFamily=Helvetica Neue;fontStyle=1;" vertex="1" parent="1">
