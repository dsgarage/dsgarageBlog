<mxfile host="draw.io">
  <diagram name="探索ベースPCGフロー" id="pcg_search_based_flow">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="700" math="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="init" value="初期集団を&#xa;ランダム生成" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f3f4f6;fontColor=#4b5563;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="160" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="represent" value="コンテンツ表現&#xa;(遺伝子型)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="160" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="evaluate" value="評価関数で&#xa;スコア算出" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="160" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="select" value="適応度に基づく&#xa;選択" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="160" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="breed" value="交叉・突然変異&#xa;(次世代生成)" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="160" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="check" value="品質基準を&#xa;満たす？" style="rhombus;whiteSpace=wrap;html=0;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="140" width="130" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="output" value="最良コンテンツ&#xa;を出力" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=#1e40af;strokeWidth=2;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="160" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="loop_label" value="世代ループ&#xa;(数十〜数千回)" style="text;html=0;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#6b7280;fontSize=9;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="950" y="260" width="100" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="f1" value="エンコード" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94a3b8;strokeWidth=1.2;endSize=5;fontSize=9;fontColor=#6b7280;fontFamily=Helvetica Neue;" edge="1" source="init" target="represent" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="f2" value="表現型に変換" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94a3b8;strokeWidth=1.2;endSize=5;fontSize=9;fontColor=#6b7280;fontFamily=Helvetica Neue;" edge="1" source="represent" target="evaluate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="f3" value="スコア順" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94a3b8;strokeWidth=1.2;endSize=5;fontSize=9;fontColor=#6b7280;fontFamily=Helvetica Neue;" edge="1" source="evaluate" target="select" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="f4" value="上位個体" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94a3b8;strokeWidth=1.2;endSize=5;fontSize=9;fontColor=#6b7280;fontFamily=Helvetica Neue;" edge="1" source="select" target="breed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="f5" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94a3b8;strokeWidth=1.2;endSize=5;" edge="1" source="breed" target="check" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="f6" value="No" style="rounded=1;orthogonalLoop=1;html=1;dashed=1;strokeColor=#cbd5e1;strokeWidth=1.2;endSize=5;fontSize=9;fontColor=#6b7280;fontFamily=Helvetica Neue;curved=1;" edge="1" source="check" target="represent" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1025" y="60"/>
              <mxPoint x="270" y="60"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="f7" value="Yes" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1e40af;strokeWidth=2;endSize=5;fontSize=9;fontColor=#1e40af;fontFamily=Helvetica Neue;" edge="1" source="check" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>