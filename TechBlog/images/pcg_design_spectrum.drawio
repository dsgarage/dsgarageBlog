<mxfile host="draw.io">
  <diagram name="PCG設計スペクトラム" id="pcg_design_spectrum">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="900" math="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- グループ背景: スペクトラム -->
        <mxCell id="bg_spectrum" value="手動設計 &#x2190;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2192; 完全自動生成" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#fafafa;strokeColor=#e5e7eb;fontColor=#6b7280;fontSize=11;fontStyle=1;fontFamily=Helvetica Neue;shadow=1;verticalAlign=top;align=center;" vertex="1" parent="1">
