        <mxCell id="title" value="Ambient Occlusion の進化" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;fontColor=#1e40af;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="470" y="15" width="260" height="30" as="geometry"/>
        </mxCell>
        <!-- Timeline arrow -->
        <mxCell id="timeline" value="" style="shape=flexArrow;endArrow=classic;startArrow=none;html=1;fillColor=#f3f4f6;strokeColor=#94a3b8;endWidth=14;endSize=5;width=8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="40" y="470" as="sourcePoint"/>
            <mxPoint x="1350" y="470" as="targetPoint"/>
