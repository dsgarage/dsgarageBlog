<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram name="Page-1" id="gameloop_update">
    <mxGraphModel dx="1100" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="750" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Game Loop -->
        <mxCell id="cluster_loop" value="Game Loop（毎フレーム実行）" style="swimlane;startSize=28;fillColor=#f8fafc;strokeColor=#e5e7eb;fontColor=#1e40af;fontSize=11;fontFamily=Helvetica Neue;rounded=1;shadow=1;fontStyle=1;swimlaneLine=0;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="560" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="input" value="processInput()&#xa;ユーザー入力処理" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_loop">
          <mxGeometry x="15" y="40" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="update_main" value="update(deltaTime)&#xa;ゲーム状態更新" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_loop">
          <mxGeometry x="205" y="40" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="render" value="render()&#xa;描画" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_loop">
          <mxGeometry x="395" y="40" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- Loop内エッジ -->
        <mxCell id="e_inp_upd" value="1" style="rounded=1;strokeColor=#94a3b8;strokeWidth=1.2;endArrow=classic;endSize=5;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" source="input" target="update_main" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_upd_ren" value="2" style="rounded=1;strokeColor=#94a3b8;strokeWidth=1.2;endArrow=classic;endSize=5;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" source="update_main" target="render" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ren_inp" value="3 次フレームへ" style="rounded=1;strokeColor=#cbd5e1;strokeWidth=1.2;dashed=1;endArrow=classic;endSize=5;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="render" target="input" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="140"/>
              <mxPoint x="120" y="140"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Update Method パターン -->
        <mxCell id="cluster_update" value="Update Method パターン" style="swimlane;startSize=28;fillColor=#fafafa;strokeColor=#e5e7eb;fontColor=#6b7280;fontSize=11;fontFamily=Helvetica Neue;rounded=1;shadow=1;fontStyle=1;swimlaneLine=0;" vertex="1" parent="1">
          <mxGeometry x="30" y="190" width="560" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="collection" value="entities[] コレクション&#xa;for (entity : entities)&#xa;    entity.update(dt)" style="rounded=1;whiteSpace=wrap;fillColor=#f3f4f6;fontColor=#4b5563;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;align=left;" vertex="1" parent="cluster_update">
          <mxGeometry x="170" y="35" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- 各オブジェクト -->
        <mxCell id="cluster_objects" value="各オブジェクトのupdate()" style="swimlane;startSize=24;fillColor=#fafafa;strokeColor=#e5e7eb;fontColor=#6b7280;fontSize=10;fontFamily=Helvetica Neue;rounded=1;shadow=1;fontStyle=1;swimlaneLine=0;" vertex="1" parent="cluster_update">
          <mxGeometry x="20" y="110" width="520" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="skeleton" value="Skeleton&#xa;パトロール移動" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_objects">
          <mxGeometry x="10" y="35" width="110" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="statue" value="Statue&#xa;雷を発射" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_objects">
          <mxGeometry x="135" y="35" width="110" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="hero" value="Hero&#xa;入力に反応" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_objects">
          <mxGeometry x="260" y="35" width="110" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="particle" value="Particle&#xa;アニメーション" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_objects">
          <mxGeometry x="385" y="35" width="110" height="55" as="geometry"/>
        </mxCell>

        <!-- collection → objects -->
        <mxCell id="e_col_sk" style="rounded=1;strokeColor=#94a3b8;strokeWidth=1.2;endArrow=classic;endSize=5;" edge="1" source="collection" target="skeleton" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_col_st" style="rounded=1;strokeColor=#94a3b8;strokeWidth=1.2;endArrow=classic;endSize=5;" edge="1" source="collection" target="statue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_col_he" style="rounded=1;strokeColor=#94a3b8;strokeWidth=1.2;endArrow=classic;endSize=5;" edge="1" source="collection" target="hero" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_col_pa" style="rounded=1;strokeColor=#94a3b8;strokeWidth=1.2;endArrow=classic;endSize=5;" edge="1" source="collection" target="particle" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ゲームエンジンでの実装 -->
        <mxCell id="cluster_engines" value="ゲームエンジンでの実装" style="swimlane;startSize=28;fillColor=#f8fafc;strokeColor=#e5e7eb;fontColor=#1e40af;fontSize=11;fontFamily=Helvetica Neue;rounded=1;shadow=1;fontStyle=1;swimlaneLine=0;" vertex="1" parent="1">
          <mxGeometry x="30" y="480" width="560" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="unity" value="Unity&#xa;MonoBehaviour.Update()&#xa;FixedUpdate() / LateUpdate()" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_engines">
          <mxGeometry x="10" y="32" width="170" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="unreal" value="Unreal Engine&#xa;AActor::Tick()&#xa;TickComponent()" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_engines">
          <mxGeometry x="195" y="32" width="170" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="godot" value="Godot&#xa;Node._process()&#xa;_physics_process()" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;" vertex="1" parent="cluster_engines">
          <mxGeometry x="380" y="32" width="170" height="65" as="geometry"/>
        </mxCell>

        <!-- update_main → collection (太線) -->
        <mxCell id="e_main_col" value="全オブジェクトを更新" style="rounded=1;strokeColor=#1e40af;strokeWidth=2;endArrow=classic;endSize=6;fontSize=9;fontFamily=Helvetica Neue;fontColor=#1e40af;" edge="1" source="update_main" target="collection" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- collection → engines (破線) -->
        <mxCell id="e_col_unity" value="具体的な実装" style="rounded=1;strokeColor=#cbd5e1;strokeWidth=1.2;dashed=1;endArrow=classic;endSize=5;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" source="collection" target="unity" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_col_unreal" style="rounded=1;strokeColor=#cbd5e1;strokeWidth=1.2;dashed=1;endArrow=classic;endSize=5;" edge="1" source="collection" target="unreal" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_col_godot" style="rounded=1;strokeColor=#cbd5e1;strokeWidth=1.2;dashed=1;endArrow=classic;endSize=5;" edge="1" source="collection" target="godot" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
