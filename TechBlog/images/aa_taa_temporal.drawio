        <mxCell id="blend_formula" value="&lt;b&gt;ブレンド:&lt;/b&gt;&lt;br&gt;出力 = &lt;font color=&quot;#4b5563&quot;&gt;0.9&lt;/font&gt; × 前フレーム&lt;br&gt;     + &lt;font color=&quot;#1e40af&quot;&gt;0.1&lt;/font&gt; × 現フレーム" style="text;html=1;align=left;fontSize=12;fontFamily=Helvetica Neue;fontColor=#92400e;spacingLeft=10;" vertex="1" parent="1">
