    <!-- Feedback loop S5 -> S2 (dashed) -->
    <mxCell id="e5" value="ズレ発見時&#xa;get_screenshotで再比較" style="rounded=1;strokeColor=#cbd5e1;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;dashed=1;" edge="1" parent="1" source="S5" target="S2">
