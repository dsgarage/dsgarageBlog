    <!-- Edge S3 -> S4 -->
    <mxCell id="e3" value="自動レビュー" style="rounded=1;strokeColor=#94a3b8;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" parent="1" source="S3" target="S4">
      <mxGeometry relative="1" as="geometry"/>
