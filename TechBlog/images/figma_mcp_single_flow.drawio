      <mxGeometry x="220" y="130" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- S3: Claude Code UXML/USS生成 (Primary) -->
    <mxCell id="S3" value="Claude Code&#xa;UXML/USS生成" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;fontColor=#1e40af;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;fontStyle=0;" vertex="1" parent="1">
      <mxGeometry x="420" y="130" width="140" height="50" as="geometry"/>
    </mxCell>

    <!-- S4: /simplify 品質チェック (Accent) -->
    <mxCell id="S4" value="/simplify&#xa;品質チェック" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;fontStyle=0;" vertex="1" parent="1">
      <mxGeometry x="620" y="130" width="130" height="50" as="geometry"/>
    </mxCell>

    <!-- S5: Unity Editor 配置・確認 (Green) -->
    <mxCell id="S5" value="Unity Editor&#xa;配置・確認" style="rounded=1;whiteSpace=wrap;fillColor=#bbf7d0;fontColor=#166534;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;fontStyle=0;" vertex="1" parent="1">
      <mxGeometry x="810" y="130" width="130" height="50" as="geometry"/>
    </mxCell>

    <!-- Edge S1 -> S2 -->
    <mxCell id="e1" value="MCP呼出" style="rounded=1;strokeColor=#94a3b8;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" parent="1" source="S1" target="S2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge S2 -> S3 -->
    <mxCell id="e2" value="React→UXML" style="rounded=1;strokeColor=#94a3b8;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" parent="1" source="S2" target="S3">
      <mxGeometry relative="1" as="geometry"/>
