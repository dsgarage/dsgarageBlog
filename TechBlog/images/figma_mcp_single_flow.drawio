    <!-- Edge S4 -> S5 -->
    <mxCell id="e4" value="コミット" style="rounded=1;strokeColor=#94a3b8;fontSize=9;fontFamily=Helvetica Neue;fontColor=#4b5563;" edge="1" parent="1" source="S4" target="S5">
