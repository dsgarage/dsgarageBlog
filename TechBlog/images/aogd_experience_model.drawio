        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#94a3b8;strokeWidth=2;fontFamily=Helvetica Neue;fontSize=10;fontColor=#64748b;" edge="1" source="game" target="player" parent="1">
          <mxGeometry relative="1" as="geometry" />
