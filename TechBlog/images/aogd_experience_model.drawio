        <mxCell id="e4" style="rounded=1;html=1;strokeColor=#cbd5e1;strokeWidth=2;dashed=1;dashPattern=8 4;endArrow=none;fontFamily=Helvetica Neue;fontSize=10;fontColor=#94a3b8;curved=1;" edge="1" source="designer" target="experience" parent="1">
