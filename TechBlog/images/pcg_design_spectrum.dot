digraph pcg_spectrum {
    rankdir=LR
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.4
    ranksep=0.8

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.08"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.5
        arrowsize=0.6
        color="#94a3b8"
    ]

    // スペクトラムの両端
    subgraph cluster_spectrum {
        label="手動設計 ←――――――――――――→ 完全自動生成"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=11
        penwidth=1

        manual [label="100% 手動設計\n(従来型開発)" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        tool [label="PCG as ツール\nSpeedTree\nTanagra" fillcolor="#dbeafe" fontcolor="#1e40af"]
        material [label="PCG as マテリアル\nフラクタル地形\nパーリンノイズ" fillcolor="#dbeafe" fontcolor="#1e40af"]
        expert [label="PCG as\nドメインエキスパート\nプレイヤーモデル" fillcolor="#fef3c7" fontcolor="#92400e"]
        designer [label="PCG as デザイナー\n完全自動ゲーム生成\n(研究段階)" fillcolor="#fef3c7" fontcolor="#92400e"]

        manual -> tool -> material -> expert -> designer
    }

    // 実用ゾーンの注釈
    subgraph cluster_practical {
        label="現在の実用ゾーン"
        labelloc=b
        labeljust=c
        style="rounded,dashed"
        color="#1e40af"
        fillcolor="transparent"
        fontcolor="#1e40af"
        fontsize=10
        penwidth=1.5

        p1 [label="Minecraft\n(マテリアル)" fillcolor="#dbeafe" fontcolor="#1e40af"]
        p2 [label="Spelunky\n(ツール+ルール)" fillcolor="#dbeafe" fontcolor="#1e40af"]
        p3 [label="Left 4 Dead\n(エキスパート)" fillcolor="#dbeafe" fontcolor="#1e40af"]
    }

    // 対応関係
    material -> p1 [style=dashed color="#cbd5e1" arrowhead=none]
    tool -> p2 [style=dashed color="#cbd5e1" arrowhead=none]
    expert -> p3 [style=dashed color="#cbd5e1" arrowhead=none]
}
