digraph magic_circle {
    rankdir=TB
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.5
    ranksep=0.8

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.10"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
        color="#94a3b8"
    ]

    // 外部（日常）
    subgraph cluster_outside {
        label="日常世界"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=11
        penwidth=1

        real_object [label="紙とプラスチック\n(物質としてのカード)" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        real_action [label="カードを出す\n(物理的動作)" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        real_meaning [label="日常的な意味\nなし" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // 境界
    boundary [label="マジックサークル\n(境界)" fillcolor="#dbeafe" fontcolor="#1e40af" fontsize=11 shape=ellipse]

    // 内部（ゲーム世界）
    subgraph cluster_inside {
        label="ゲーム世界"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#93c5fd"
        fillcolor="#f8fafc"
        fontcolor="#1e40af"
        fontsize=11
        penwidth=1

        game_object [label="魔法のカード\n攻撃力7・コスト3" fillcolor="#dbeafe" fontcolor="#1e40af"]
        game_action [label="攻撃を宣言\n戦略的選択" fillcolor="#fef3c7" fontcolor="#92400e"]
        game_meaning [label="勝敗に直結する\n意味のある行為" fillcolor="#dcfce7" fontcolor="#166534"]
    }

    real_object -> boundary [label="入る" color="#94a3b8"]
    boundary -> game_object [label="変容する" color="#3b82f6"]

    real_action -> boundary [style=dashed color="#cbd5e1"]
    boundary -> game_action [style=dashed color="#cbd5e1"]

    game_object -> game_action -> game_meaning [color="#94a3b8"]
}
