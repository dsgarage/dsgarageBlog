    <mxCell id="c_workers_label" value="Phase 3: 並列実行（各 git worktree で隔離）" style="text;fontSize=10;fontColor=#166534;align=center;fontFamily=Helvetica Neue;fontStyle=1;" vertex="1" parent="1">
