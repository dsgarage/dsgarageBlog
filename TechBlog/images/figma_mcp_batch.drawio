      <mxGeometry x="670" y="130" width="130" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="ep1" style="rounded=1;strokeColor=#94a3b8;" edge="1" parent="1" source="metadata" target="tokens"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ep2" style="rounded=1;strokeColor=#94a3b8;" edge="1" parent="1" source="tokens" target="decompose"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ep3" style="rounded=1;strokeColor=#94a3b8;" edge="1" parent="1" source="decompose" target="approve"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- input -> metadata -->
    <mxCell id="ei" style="rounded=1;strokeColor=#94a3b8;" edge="1" parent="1" source="input" target="metadata">
