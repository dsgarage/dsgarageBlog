        <mxCell id="mono" value="PlayerCharacter&#xa;━━━━━━━━━━━━━━&#xa;入力処理&#xa;物理演算&#xa;描画&#xa;サウンド&#xa;AI&#xa;━━━━━━━━━━━━━━&#xa;5000行の巨大クラス" style="rounded=1;whiteSpace=wrap;fillColor=#fef3c7;fontColor=#92400e;strokeColor=none;fontSize=10;fontFamily=Helvetica Neue;shadow=1;align=center;" vertex="1" parent="cluster_before">
