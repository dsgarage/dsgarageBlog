        </mxCell>
        <mxCell id="bn1" value="CPU-bound: CPUの状態変更処理が&#xa;遅く、GPUが命令待ち" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#92400e;fontFamily=Helvetica Neue;" vertex="1" parent="1">
