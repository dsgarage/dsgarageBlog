        <!-- Key insight -->
        <mxCell id="insight" value="💡 ドローコールの「数」より&#xa;　 状態変更の「重さ」が問題" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#1e40af;fontFamily=Helvetica Neue;" vertex="1" parent="1">
