digraph learning_curve {
    rankdir=TB
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.5
    ranksep=0.8

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.08"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
        color="#94a3b8"
    ]

    subgraph cluster_anxiety {
        label="不安ゾーン\n(難しすぎる)"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#fca5a5"
        fillcolor="#fef2f2"
        fontcolor="#991b1b"
        fontsize=10
        penwidth=1

        anxiety [label="挫折・離脱\nパターンが複雑すぎて\n脳が処理できない" fillcolor="#fee2e2" fontcolor="#991b1b"]
    }

    subgraph cluster_flow {
        label="フローゾーン\n(ちょうどいい)"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#86efac"
        fillcolor="#f0fdf4"
        fontcolor="#166534"
        fontsize=10
        penwidth=1

        flow [label="楽しさの最大化\nパターンが徐々に\n解き明かされていく" fillcolor="#dcfce7" fontcolor="#166534" fontsize=11]
    }

    subgraph cluster_boredom {
        label="退屈ゾーン\n(簡単すぎる)"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=10
        penwidth=1

        boredom [label="飽き・離脱\nパターンを完全に習得し\n新しい発見がない" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // 難易度軸
    challenge [label="チャレンジ\n(難易度)" fillcolor="#dbeafe" fontcolor="#1e40af"]
    skill [label="スキル\n(プレイヤーの能力)" fillcolor="#fef3c7" fontcolor="#92400e"]

    challenge -> anxiety [label="高すぎる" color="#94a3b8"]
    challenge -> flow [label="適切" color="#94a3b8"]
    skill -> flow [label="成長中" color="#94a3b8"]
    skill -> boredom [label="上回る" color="#94a3b8"]
}
