<mxfile>
  <diagram name="Forward Rendering" id="forward_flow">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="Forward Rendering ― 各オブジェクトですべてのライトを計算" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;fontColor=#1e40af;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="220" y="10" width="500" height="30" as="geometry"/>
        </mxCell>
        <!-- Object loop -->
        <mxCell id="obj_loop" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e5e7eb;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="500" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="obj_label" value="for each オブジェクト (N個)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#1e40af;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="40" y="65" width="200" height="20" as="geometry"/>
        </mxCell>
        <!-- Object -->
        <mxCell id="obj" value="オブジェクト&#xa;(頂点・マテリアル)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#93c5fd;fontColor=#1e40af;fontSize=10;fontFamily=Helvetica Neue;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="110" width="120" height="50" as="geometry"/>
        </mxCell>
        <!-- Light loop -->
        <mxCell id="light_loop" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#fcd34d;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="90" width="200" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="light_label" value="for each ライト (M個)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontStyle=1;fontColor=#92400e;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="220" y="95" width="150" height="20" as="geometry"/>
        </mxCell>
        <!-- Shading -->
        <mxCell id="shade" value="ライティング計算&#xa;色 += shading(obj, light)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#fcd34d;fontColor=#92400e;fontSize=10;fontFamily=Helvetica Neue;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="130" width="160" height="50" as="geometry"/>
        </mxCell>
        <!-- Overdraw warning -->
        <mxCell id="overdraw" value="⚠ 見えないピクセルも&#xa;計算してしまう&#xa;（オーバードロー）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#fca5a5;fontColor=#991b1b;fontSize=10;fontFamily=Helvetica Neue;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="190" width="160" height="45" as="geometry"/>
        </mxCell>
        <!-- Write to framebuffer -->
        <mxCell id="fb" value="フレーム&#xa;バッファに&#xa;書き込み" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#86efac;fontColor=#166534;fontSize=10;fontFamily=Helvetica Neue;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="110" width="80" height="50" as="geometry"/>
        </mxCell>
        <!-- Arrows -->
        <mxCell id="e1" style="rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#94a3b8;strokeWidth=1.5;" edge="1" source="obj" target="shade" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="rounded=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;strokeColor=#94a3b8;strokeWidth=1.5;" edge="1" source="light_loop" target="fb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Complexity -->
        <mxCell id="complexity" value="計算量: O(N × M)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=1;fontColor=#92400e;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="350" y="280" width="130" height="30" as="geometry"/>
        </mxCell>
        <!-- Right side: result -->
        <mxCell id="result_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e5e7eb;" vertex="1" parent="1">
          <mxGeometry x="570" y="60" width="220" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="result_title" value="特性" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#1e40af;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="580" y="65" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="pro1" value="✅ 透明オブジェクト対応" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#166534;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="580" y="95" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="pro2" value="✅ MSAA対応" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#166534;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="580" y="115" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="pro3" value="✅ メモリ消費が少ない" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#166534;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="580" y="135" width="150" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="con1" value="❌ オーバードロー" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#991b1b;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="580" y="170" width="130" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="con2" value="❌ 多数ライトに弱い" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#991b1b;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="580" y="190" width="140" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="games" value="採用: Heavy Rain, Just Cause 1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#6b7280;fontFamily=Helvetica Neue;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="225" width="190" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
