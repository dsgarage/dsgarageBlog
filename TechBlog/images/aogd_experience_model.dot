digraph experience_model {
    rankdir=LR
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.6
    ranksep=1.2

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.10"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
    ]

    // デザイナー
    designer [label="デザイナー\n(Designer)" fillcolor="#dbeafe" fontcolor="#1e40af"]

    // ゲーム
    game [label="ゲーム\n(Game)" fillcolor="#fef3c7" fontcolor="#92400e"]

    // プレイヤー
    player [label="プレイヤー\n(Player)" fillcolor="#f3f4f6" fontcolor="#4b5563"]

    // 体験
    experience [label="体 験\n(Experience)" fillcolor="#dcfce7" fontcolor="#166534" shape=ellipse fontsize=12]

    // 関係
    designer -> game [label="設計する\n(直接制御)" color="#94a3b8"]
    game -> player [label="インタラクション" color="#94a3b8"]
    player -> experience [label="心の中に生まれる" color="#94a3b8"]

    // デザイナーは体験を直接制御できない
    designer -> experience [label="直接制御できない" style=dashed color="#cbd5e1" arrowhead=none]
}
