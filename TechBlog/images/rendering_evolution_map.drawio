        <mxCell id="unity1" value="URP Forward / Forward+  → モバイル・VR" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#4b5563;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="260" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="unity2" value="URP Deferred            → 中規模プロジェクト" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#4b5563;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="80" y="348" width="290" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="unity3" value="HDRP Deferred           → AAA品質" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=9;fontColor=#4b5563;fontFamily=Helvetica Neue;" vertex="1" parent="1">
          <mxGeometry x="80" y="366" width="230" height="16" as="geometry"/>
