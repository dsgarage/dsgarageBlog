digraph mda_dual_perspective {
    rankdir=TB
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.8
    ranksep=0.8

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.10"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
    ]

    // デザイナー視点
    subgraph cluster_designer {
        label="デザイナーの視点"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#93c5fd"
        fillcolor="#f8fafc"
        fontcolor="#1e40af"
        fontsize=11
        penwidth=1

        d_m [label="Mechanics\nルールを設計する" fillcolor="#dbeafe" fontcolor="#1e40af"]
        d_d [label="Dynamics\n振る舞いを予測する" fillcolor="#dbeafe" fontcolor="#1e40af"]
        d_a [label="Aesthetics\n感情を意図する" fillcolor="#dbeafe" fontcolor="#1e40af"]

        d_m -> d_d -> d_a [color="#3b82f6" label="→"]
    }

    // プレイヤー視点
    subgraph cluster_player {
        label="プレイヤーの視点"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#fcd34d"
        fillcolor="#fffbeb"
        fontcolor="#92400e"
        fontsize=11
        penwidth=1

        p_a [label="Aesthetics\n感情を体験する" fillcolor="#fef3c7" fontcolor="#92400e"]
        p_d [label="Dynamics\n振る舞いを観察する" fillcolor="#fef3c7" fontcolor="#92400e"]
        p_m [label="Mechanics\nルールを発見する" fillcolor="#fef3c7" fontcolor="#92400e"]

        p_a -> p_d -> p_m [color="#d97706" label="→"]
    }

    // 対比
    d_a -> p_a [style=dashed color="#cbd5e1" arrowhead=none label="同じ層、逆の方向" fontsize=8]
}
