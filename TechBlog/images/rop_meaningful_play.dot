digraph meaningful_play {
    rankdir=LR
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.6
    ranksep=1.0

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.10"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
        color="#94a3b8"
    ]

    // プレイヤーの行為
    action [label="プレイヤーの\nアクション" fillcolor="#dbeafe" fontcolor="#1e40af" fontsize=11]

    // 2条件
    subgraph cluster_conditions {
        label="「意味のあるプレイ」の2条件"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#f8fafc"
        fontcolor="#1e40af"
        fontsize=11
        penwidth=1

        discernable [label="Discernable\n識別可能\n結果がすぐ分かる" fillcolor="#fef3c7" fontcolor="#92400e"]
        integrated [label="Integrated\n統合的\nゲーム全体に影響する" fillcolor="#fef3c7" fontcolor="#92400e"]
    }

    // 結果
    meaningful [label="意味のあるプレイ\n(Meaningful Play)" fillcolor="#dcfce7" fontcolor="#166534" fontsize=12]
    not_meaningful [label="無意味なプレイ\n(退屈 or 混乱)" fillcolor="#fee2e2" fontcolor="#991b1b"]

    action -> discernable [label="結果が見える?"]
    action -> integrated [label="全体に影響する?"]

    discernable -> meaningful [label="Yes" color="#16a34a"]
    integrated -> meaningful [label="Yes" color="#16a34a"]
    discernable -> not_meaningful [label="No" style=dashed color="#cbd5e1"]
    integrated -> not_meaningful [label="No" style=dashed color="#cbd5e1"]
}
