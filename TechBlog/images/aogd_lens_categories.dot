digraph lens_categories {
    rankdir=TB
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.5
    ranksep=0.8

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.10"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
        color="#94a3b8"
    ]

    // 中心
    center [label="112のレンズ\n(Lenses)" fillcolor="#dbeafe" fontcolor="#1e40af" fontsize=12 shape=ellipse]

    // 4つのカテゴリ（エレメンタル・テトラッド）
    subgraph cluster_tetrad {
        label="エレメンタル・テトラッド"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#f8fafc"
        fontcolor="#1e40af"
        fontsize=11
        penwidth=1

        mech [label="メカニクス\n空間・時間・ルール\nアクション・確率" fillcolor="#dbeafe" fontcolor="#1e40af"]
        story [label="ストーリー\nキャラクター・世界観\n興味曲線・テーマ" fillcolor="#fef3c7" fontcolor="#92400e"]
        aesthetics [label="美学\nアート・音楽\nUI・雰囲気" fillcolor="#dcfce7" fontcolor="#166534"]
        tech [label="テクノロジー\nプラットフォーム\n技術的制約" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // プレイヤー関連
    subgraph cluster_player {
        label="プレイヤー理解"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=11
        penwidth=1

        psych [label="心理・動機\nフロー・快楽\n認知負荷" fillcolor="#fef3c7" fontcolor="#92400e"]
        demo [label="デモグラフィクス\n年齢・性別\nプレイスタイル" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // プロセス関連
    subgraph cluster_process {
        label="デザインプロセス"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=11
        penwidth=1

        iter [label="イテレーション\nプロトタイプ\nプレイテスト" fillcolor="#dbeafe" fontcolor="#1e40af"]
        team [label="チーム\nコミュニケーション\nピッチング" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // 接続
    center -> mech
    center -> story
    center -> aesthetics
    center -> tech
    center -> psych
    center -> demo
    center -> iter
    center -> team
}
