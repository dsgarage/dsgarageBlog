digraph CodeVsSettings {
    graph [
        rankdir=LR
        bgcolor="transparent"
        fontname="Helvetica Neue"
        fontsize=11
        pad=0.5
        nodesep=0.4
        ranksep=0.8
        compound=true
    ]

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.12,0.08"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=2
    ]

    // AI領域（青系）
    subgraph cluster_ai {
        label="✓ AI が書ける"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#f8fafc"
        fontcolor="#1e40af"
        fontsize=11
        penwidth=1

        script [label="C# Script" fillcolor="#dbeafe" fontcolor="#1e40af"]
        shader [label="Shader" fillcolor="#dbeafe" fontcolor="#1e40af"]
        config [label="Config" fillcolor="#dbeafe" fontcolor="#1e40af"]
    }

    // 壁
    wall [
        label="壁"
        shape=box
        style="filled,rounded"
        fillcolor="#fef3c7"
        fontcolor="#92400e"
        fontsize=14
        width=0.8
        height=1.6
        fixedsize=true
    ]

    // Unity Editor領域（グレー系）
    subgraph cluster_unity {
        label="Unity Editor"
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=11
        penwidth=1

        scene [label="Scene" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        gameobject [label="GameObject" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        component [label="Component" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        inspector [label="Inspector" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // クラスタから壁へ（ltailでクラスタ境界から線を出す）
    shader -> wall [ltail=cluster_ai color="#1e40af" style=bold]

    // 壁からクラスタへ（lheadでクラスタ境界へ線を入れる）
    wall -> gameobject [lhead=cluster_unity style=dashed color="#dc2626" label=" ✗ " fontcolor="#dc2626" fontsize=16]
}
