// .env 平文保管の脅威モデル — AIエージェント時代のリスク
digraph env_threat {
    rankdir=TB
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.5
    nodesep=0.5
    ranksep=0.6

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.12,0.08"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
        color="#94a3b8"
    ]

    // 中心: .envファイル
    dotenv [label=".env\n（平文APIキー）" fillcolor="#fef3c7" fontcolor="#92400e"]

    // 攻撃ベクトル
    subgraph cluster_threats {
        label="  脅威ベクトル  "
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=10
        penwidth=1

        t1 [label="うっかり\ngit commit" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        t2 [label="シェル履歴\nへの混入" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        t3 [label="AIエージェント\nによる抽出" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        t4 [label="CI/CD\nトークン窃取" fillcolor="#f3f4f6" fontcolor="#4b5563"]
    }

    // 被害
    subgraph cluster_impact {
        label="  被害  "
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=10
        penwidth=1

        i1 [label="APIキー漏洩\n課金被害" fillcolor="#fef3c7" fontcolor="#92400e"]
        i2 [label="リポジトリ\n乗っ取り" fillcolor="#fef3c7" fontcolor="#92400e"]
        i3 [label="サプライチェーン\n攻撃" fillcolor="#fef3c7" fontcolor="#92400e"]
    }

    // エッジ
    dotenv -> t1 [label=".gitignore漏れ"]
    dotenv -> t2 [label="export/echo"]
    dotenv -> t3 [label="cat .env"]
    dotenv -> t4 [label="Actions内で参照"]

    t1 -> i1
    t2 -> i1
    t3 -> i1
    t4 -> i2
    t4 -> i3
}
