// lkr exec ワークフロー — Keychain → 環境変数注入
digraph lkr_exec {
    rankdir=LR
    bgcolor="transparent"
    fontname="Helvetica Neue"
    fontsize=11
    pad=0.8
    nodesep=0.6
    ranksep=0.8

    node [
        fontname="Helvetica Neue"
        fontsize=10
        style="filled,rounded"
        shape=box
        penwidth=0
        margin="0.15,0.1"
    ]

    edge [
        fontname="Helvetica Neue"
        fontsize=9
        penwidth=1.2
        arrowsize=0.6
        color="#94a3b8"
    ]

    // 従来フロー
    subgraph cluster_old {
        label="  従来: .env 平文  "
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#fafafa"
        fontcolor="#6b7280"
        fontsize=10
        penwidth=1

        o1 [label=".env ファイル\n（平文）" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        o2 [label="source .env\nexport" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        o3 [label="アプリ実行" fillcolor="#f3f4f6" fontcolor="#4b5563"]
        o4 [label="平文がディスク\nに常駐" fillcolor="#fef3c7" fontcolor="#92400e"]

        o1 -> o2 [label="読み込み"]
        o2 -> o3 [label="環境変数"]
        o1 -> o4 [label="リスク" style=dashed color="#cbd5e1"]
    }

    // lkr フロー
    subgraph cluster_new {
        label="  lkr exec: Keychain 経由  "
        labelloc=t
        labeljust=c
        style="rounded,filled"
        color="#e5e7eb"
        fillcolor="#f8fafc"
        fontcolor="#1e40af"
        fontsize=10
        penwidth=1

        n1 [label="macOS\nKeychain" fillcolor="#dbeafe" fontcolor="#1e40af"]
        n2 [label="lkr exec\nTTYガード" fillcolor="#dbeafe" fontcolor="#1e40af"]
        n3 [label="子プロセス\n環境変数のみ" fillcolor="#dbeafe" fontcolor="#1e40af"]
        n4 [label="ディスクに\n平文なし" fillcolor="#bbf7d0" fontcolor="#166534"]

        n1 -> n2 [label="復号"]
        n2 -> n3 [label="env注入"]
        n2 -> n4 [label="安全" style=dashed color="#cbd5e1"]
    }
}
