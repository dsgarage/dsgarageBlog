<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="SimpleUIFlow StateGraph（4画面遷移）" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="60" y="10" width="500" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="st_title" value="Title" style="rounded=1;whiteSpace=wrap;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="60" y="80" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="st_title_start" value="START" style="text;html=1;fontSize=9;fontStyle=1;fontColor=#FFFFFF;fillColor=#6C8EBF;rounded=1;spacing=2;align=center;" vertex="1" parent="1">
      <mxGeometry x="90" y="65" width="40" height="14" as="geometry"/>
    </mxCell>
    <mxCell id="st_home" value="Home" style="rounded=1;whiteSpace=wrap;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="260" y="80" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="st_game" value="Game" style="rounded=1;whiteSpace=wrap;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="460" y="80" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="st_result" value="Result" style="rounded=1;whiteSpace=wrap;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="460" y="220" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="t1" value="Tap to Start" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6C8EBF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="st_title" target="st_home">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="t2" value="Play" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82B366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="st_home" target="st_game">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="t3" value="Finish" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#B85450;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="st_game" target="st_result">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="t4" value="Back to Home" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673A6;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="st_result" target="st_home">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="320" y="250"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="fg_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=none;strokeColor=#999999;dashed=1;strokeWidth=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="180" width="310" height="120" as="geometry"/>
    </mxCell>
    <mxCell id="fg_label" value="Title ステート内の FlowGraph" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#999999;align=left;" vertex="1" parent="1">
      <mxGeometry x="40" y="183" width="200" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="fg_event" value="CustomEvent&#xa;&quot;Next&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="50" y="210" width="110" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="fg_trans" value="TriggerState&#xa;Transition" style="rounded=1;whiteSpace=wrap;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="210" y="210" width="110" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="fg_conn" value="trigger" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#D6B656;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="fg_event" target="fg_trans">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="detail_arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;dashed=1;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="st_title" target="fg_box">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
