<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="title" value="Visual Scripting API 呼び出しフロー" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="120" y="10" width="560" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s1_label" value="Step 1" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#6C8EBF;align=center;" vertex="1" parent="1">
      <mxGeometry x="30" y="70" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="s1" value="stateGraph.createFromDefinition" style="rounded=1;whiteSpace=wrap;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="60" width="280" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s1_desc" value="4ステート + 4トランジション&#xa;を JSON 一発で生成" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="220" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6C8EBF;strokeWidth=2;" edge="1" parent="1" source="s1" target="s2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="s2_label" value="Step 2" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#82B366;align=center;" vertex="1" parent="1">
      <mxGeometry x="30" y="150" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="s2" value="flowGraph.createFromDefinition" style="rounded=1;whiteSpace=wrap;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="140" width="280" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s2_desc" value="各ステート内に&#xa;CustomEvent → TriggerStateTransition&#xa;のノード＋接続を構築" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="420" y="133" width="280" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="s2" target="s3">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="s3_label" value="Step 3" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#D6B656;align=center;" vertex="1" parent="1">
      <mxGeometry x="30" y="230" width="60" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="s3" value="stateMachine.setGraph" style="rounded=1;whiteSpace=wrap;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="220" width="280" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="s3_desc" value="GameObject の StateMachine に&#xa;StateGraphAsset を Macro として割り当て" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="420" y="213" width="280" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#B85450;strokeWidth=2;" edge="1" parent="1" source="s3" target="result">
