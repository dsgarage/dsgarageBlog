    </mxCell>
    <mxCell id="result" value="Play モードで画面遷移が動作" style="rounded=1;whiteSpace=wrap;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="100" y="310" width="280" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="new1" value="NEW" style="text;html=1;fontSize=9;fontStyle=1;fontColor=#FFFFFF;fillColor=#82B366;rounded=1;spacing=2;" vertex="1" parent="1">
