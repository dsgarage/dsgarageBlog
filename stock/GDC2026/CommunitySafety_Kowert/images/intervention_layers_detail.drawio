        <mxCell id="phase3_header" value="&#x2462; ポリシー + エンフォースメント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#be185d;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="480" width="340" height="35" as="geometry"/>
