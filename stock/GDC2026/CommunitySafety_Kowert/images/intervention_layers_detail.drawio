        <mxCell id="phase2_who" value="Mike Pappas (Modulate) + Maria Tamellini (GamerSafer)" style="text;html=1;fontSize=10;fontColor=#64748b;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="430" y="515" width="340" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_item1" value="&lt;b&gt;ToxMod: AI音声モデレーション&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;テキスト変換ではなく声のトーン・&lt;br&gt;周囲の反応・文脈を分析&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fef08a;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="445" y="545" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_item2" value="&lt;b&gt;本人確認 + 年齢認証&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;認証済み = 違反率1/3に低下&lt;br&gt;BAN回避も防止&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fef08a;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="445" y="610" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_item3" value="&lt;b&gt;CoD実績データ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;常習違反者 月次8%減少&lt;br&gt;ユーザーレポート正確率 &amp;lt;25%&lt;br&gt;→ プロアクティブ検出が不可欠&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fef08a;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="445" y="675" width="310" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_quote" value="&lt;i&gt;「トラッシュトークとハラスメントの&lt;br&gt;区別はテキストでは不可能」&lt;/i&gt;" style="text;html=1;fontSize=10;fontColor=#64748b;align=center;" vertex="1" parent="1">
          <mxGeometry x="445" y="750" width="310" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_result" value="&#x2714; 善意のプレイヤーは知らせるだけで変わる&lt;br&gt;少数の悪質ユーザーには別アプローチ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=none;fontColor=#854d0e;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="445" y="790" width="310" height="50" as="geometry"/>
