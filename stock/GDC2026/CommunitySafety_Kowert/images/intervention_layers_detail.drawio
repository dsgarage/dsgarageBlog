          <mxGeometry x="70" y="515" width="340" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_item1" value="&lt;b&gt;リスクアセスメント&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;新機能リリース前に「この環境は&lt;br&gt;リスクを生まないか？」を評価&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bfdbfe;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="545" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_item2" value="&lt;b&gt;UXデザインでルールを体現&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ボイスチャット不要プレイヤーの&lt;br&gt;マッチメイキング分離など&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bfdbfe;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="610" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_item3" value="&lt;b&gt;Digital Thriving Playbook&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;120記事のエビデンスベースの&lt;br&gt;業界ベストプラクティス集&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bfdbfe;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="85" y="675" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_quote" value="&lt;i&gt;「結果が出てから対処するだけでは&lt;br&gt;望ましい行動は促せない」&lt;/i&gt;" style="text;html=1;fontSize=10;fontColor=#64748b;align=center;" vertex="1" parent="1">
          <mxGeometry x="85" y="740" width="310" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="phase1_result" value="&#x2714; プレイヤーはポリシーを読まない&lt;br&gt;→ ゲーム自体がルールを反映" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=none;fontColor=#1e40af;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="85" y="785" width="310" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="phase2_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#fef08a;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="480" width="340" height="370" as="geometry"/>
        </mxCell>
        <mxCell id="phase2_header" value="&#x2461; プロアクティブ検出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ca8a04;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="480" width="340" height="35" as="geometry"/>
