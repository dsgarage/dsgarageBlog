        <mxCell id="phase3_who" value="Savannah Badalich (Discord) + Maria Tamellini (GamerSafer)" style="text;html=1;fontSize=10;fontColor=#64748b;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="790" y="515" width="340" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_item1" value="&lt;b&gt;文脈を理解するガイドライン&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;「崖から飛び降りたい」=ゲーム内は文字通り&lt;br&gt;Twitter とは異なる文脈&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fbcfe8;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="805" y="545" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_item2" value="&lt;b&gt;教育的エンフォースメント&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;「スパム → メディアアップロード制限」&lt;br&gt;行動制限 + 理由説明を同時に&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fbcfe8;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="805" y="610" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_item3" value="&lt;b&gt;Living Policy（生きたポリシー）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;言語・文化・AIの進化に合わせて常に更新&lt;br&gt;静的文書ではなく進化するシステム&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fbcfe8;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="805" y="675" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_quote" value="&lt;i&gt;「ポリシーは家の土台。&lt;br&gt;コミュニティが家を装飾する」&lt;/i&gt;" style="text;html=1;fontSize=10;fontColor=#64748b;align=center;" vertex="1" parent="1">
          <mxGeometry x="805" y="740" width="310" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="phase3_result" value="&#x2714; 責任なき自律性 = カオス&lt;br&gt;一貫性なき介入 = 権威主義" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=none;fontColor=#be185d;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="805" y="785" width="310" height="50" as="geometry"/>
