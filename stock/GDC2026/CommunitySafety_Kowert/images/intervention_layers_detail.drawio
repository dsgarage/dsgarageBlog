        <mxCell id="phase1_header" value="&#x2460; Safety by Design" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e40af;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1">
