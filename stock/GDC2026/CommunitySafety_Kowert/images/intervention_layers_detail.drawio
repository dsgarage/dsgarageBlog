        </mxCell>
        <mxCell id="phase4_item1" value="&lt;b&gt;GS Academy（モデレーター教育）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;無料 / エンパワーメント型&lt;br&gt;画一ルールではなく判断力を育成&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbf7d0;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1165" y="545" width="350" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase4_item2" value="&lt;b&gt;Teen Council（ティーン評議会）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Discord: 13-17歳の当事者の声を反映&lt;br&gt;米国開始 → グローバル展開予定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbf7d0;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1165" y="610" width="350" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="phase4_item3" value="&lt;b&gt;プレイヤーがプレイヤーを教育&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;VRタイトルのDiscordで他プレイヤーが&lt;br&gt;プライバシー懸念に先に回答する現象&lt;br&gt;技術ドキュメント公開 → 自律的教育&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbf7d0;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1165" y="675" width="350" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="phase4_item4" value="&lt;b&gt;フィードバックループ&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;報告 → 対応 → 結果通知&lt;br&gt;(LoLの通知機能が好例)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbf7d0;fontColor=#1e293b;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
