    </mxCell>
    <mxCell id="s1_label" value="&lt;b&gt;Stage 1: 単一ボディパーツ抽出&lt;/b&gt; (Local)" style="text;html=1;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="20" y="195" width="300" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="s1_input" value="&lt;b&gt;入力画像 I&lt;/b&gt;&#xa;+&#xa;クラスラベル c_k&#xa;(例: &quot;hair&quot;)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;html=1;whiteSpace=wrap;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
