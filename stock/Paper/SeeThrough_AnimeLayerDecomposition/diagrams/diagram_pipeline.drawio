    <mxCell id="s2_label" value="&lt;b&gt;Stage 2: 整合的ボディパーツ分解&lt;/b&gt; (Global)" style="text;html=1;fontSize=12;align=left;fillColor=none;strokeColor=none;fontColor=#82b366;" vertex="1" parent="1">
