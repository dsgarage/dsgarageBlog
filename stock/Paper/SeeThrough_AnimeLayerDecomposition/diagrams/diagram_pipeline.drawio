    <mxCell id="s2_input" value="&lt;b&gt;入力画像 I&lt;/b&gt;&#xa;+&#xa;全クラスラベル&#xa;C = {c_1,...,c_N}" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;html=1;whiteSpace=wrap;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
      <mxGeometry x="20" y="385" width="130" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="s2_unet" value="&lt;b&gt;SDXL U-Net&lt;/b&gt;&#xa;+&#xa;&lt;b&gt;Body Part Consistency&#xa;Module (BPCM)&lt;/b&gt;&#xa;&#xa;N パーツを c 次元に&#xa;スタックして同時デノイズ" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;html=1;whiteSpace=wrap;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
      <mxGeometry x="200" y="380" width="190" height="110" as="geometry"/>
    </mxCell>
    <mxCell id="bpcm_box" value="&lt;b&gt;BPCM&lt;/b&gt;&#xa;パーツ次元 c に沿って&#xa;アテンション実行" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;html=1;whiteSpace=wrap;dashed=1;" vertex="1" parent="1">
