    <mxCell id="a_rgba_final" style="strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.7;entryY=0;" edge="1" parent="1" source="s2_out" target="final">
