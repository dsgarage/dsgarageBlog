    <mxCell id="s2_out" value="&lt;b&gt;19パーツ全て&lt;/b&gt;&#xa;整合的 RGBA&#xa;レイヤーセット&#xa;{L̂_1,...,L̂_N}" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;html=1;whiteSpace=wrap;verticalAlign=top;spacingTop=3;" vertex="1" parent="1">
