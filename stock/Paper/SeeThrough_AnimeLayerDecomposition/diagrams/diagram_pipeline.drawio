    </mxCell>
    <mxCell id="depth_out" value="&lt;b&gt;擬似深度マップ&lt;/b&gt;&#xa;{D_1,...,D_N}&#xa;描画順序" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;html=1;whiteSpace=wrap;" vertex="1" parent="1">
