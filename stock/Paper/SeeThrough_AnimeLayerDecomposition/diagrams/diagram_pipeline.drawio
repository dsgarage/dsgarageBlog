    <mxCell id="marigold" value="&lt;b&gt;Marigold&lt;/b&gt;&#xa;(ファインチューン)&#xa;+&#xa;BPCM" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;html=1;whiteSpace=wrap;" vertex="1" parent="1">
