    <mxCell id="depth_label" value="&lt;b&gt;+ 擬似深度推論&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;fillColor=none;strokeColor=none;fontColor=#9673a6;" vertex="1" parent="1">
