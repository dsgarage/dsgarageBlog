    <mxCell id="final" value="&lt;b&gt;2.5D キャラクターモデル&lt;/b&gt;&#xa;&#xa;層化 RGBA レイヤー&#xa;+ 描画順序&#xa;→ アニメーション可能" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;html=1;whiteSpace=wrap;verticalAlign=top;spacingTop=5;strokeWidth=2;" vertex="1" parent="1">
