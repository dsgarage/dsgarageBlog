    <mxCell id="a_bpcm" style="strokeColor=#b85450;strokeWidth=1;endArrow=block;endFill=1;dashed=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s2_unet" target="bpcm_box">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="s2_decode" value="&lt;b&gt;D_x + D_a&lt;/b&gt;&#xa;全パーツ&#xa;デコード" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;html=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="450" y="400" width="100" height="60" as="geometry"/>
